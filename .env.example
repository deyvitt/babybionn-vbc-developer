# Copy this file to .env and fill in your values

# ============ APPLICATION ============
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8001
WORKERS=2
RELOAD=true

# ============ SECURITY ============
SECRET_KEY=change-this-in-production
API_KEY=your-api-key-here

# ============ LLM GATEWAY API KEYS ============
# Primary: DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Fallback: OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============ PATHS ============
KNOWLEDGE_BASE_DIR=./knowledge_bases
MESH_PATTERNS_DIR=./mesh_patterns
CHECKPOINTS_DIR=./checkpoints

# ============ NEURAL MESH ============
NEURAL_MESH_ENABLED=true
MESH_LEARNING_RATE=0.1
MESH_ACTIVATION_THRESHOLD=0.3
MAX_CONCURRENT_VNIS=10
MESH_CACHE_SIZE=1000

# ============ LLM GATEWAY SETTINGS ============
LLM_PROVIDER_PRIORITY=deepseek,openai
LLM_REQUEST_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600
LLM_CACHE_SIZE=1000

# VNI Temperature Settings
VNI_MEDICAL_TEMPERATURE=0.1
VNI_LEGAL_TEMPERATURE=0.1
VNI_TECHNICAL_TEMPERATURE=0.2
VNI_GENERAL_TEMPERATURE=0.3

# Analytics
COST_TRACKING_ENABLED=true

# ============ EXTERNAL SERVICES ============
# REDIS_URL=redis://localhost:6379/0
# DATABASE_URL=postgresql://user:pass@localhost:5432/babybionn

# ============ MONITORING ============
# OTEL_SERVICE_NAME=babybionn
# PROMETHEUS_MULTIPROC_DIR=./prometheus_data
